# Phoenix LLM Settings
# Choose one of: gemini (default), claude
PHOENIX_LLM=gemini

# API Keys (fill in the one you use)
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

